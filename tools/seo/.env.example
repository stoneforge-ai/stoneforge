KEYWORDS_EVERYWHERE_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google Search Console API (service account auth)
# See: bun run tools/seo/search-console.ts --help for setup instructions
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json
# Comma-separated list of site URLs verified in Google Search Console
GSC_SITE_URLS=https://stoneforge.ai,https://docs.stoneforge.ai
# Legacy single-site config (still supported as fallback):
# GSC_SITE_URL=https://stoneforge.ai
