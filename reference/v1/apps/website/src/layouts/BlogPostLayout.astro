---
import BaseLayout from './BaseLayout.astro';
import PostMeta from '../components/blog/PostMeta.astro';
import TagList from '../components/blog/TagList.astro';
import RelatedContent from '../components/ui/RelatedContent.astro';

interface RelatedItem {
  title: string;
  url: string;
  type: 'docs' | 'blog' | 'use-case' | 'compare';
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  author: { name: string; url?: string; avatar?: string };
  image?: string;
  tags: string[];
  slug: string;
  relatedContent?: RelatedItem[];
}

const { title, description, date, updatedDate, author, image, tags, slug, relatedContent } = Astro.props;
const canonicalUrl = new URL(`/blog/${slug}/`, Astro.site).href;
const ogImage = image || '/og.png';
const wordCount = Astro.slots.has('default') ? 0 : 0; // computed at render
---

<BaseLayout title={`${title} — Stoneforge Blog`} description={description} image={ogImage} canonicalUrl={canonicalUrl}>
  <Fragment slot="head">
    <!-- Override OG type for article -->
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={date.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <meta property="article:author" content={author.name} />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- BlogPosting JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "datePublished": date.toISOString(),
      "dateModified": (updatedDate || date).toISOString(),
      "url": canonicalUrl,
      "image": new URL(ogImage, Astro.site).href,
      "keywords": tags.join(', '),
      "author": {
        "@type": "Person",
        "name": author.name,
        ...(author.url ? { "url": author.url } : {}),
      },
      "publisher": {
        "@type": "Organization",
        "name": "Stoneforge",
        "url": "https://stoneforge.ai",
        "logo": {
          "@type": "ImageObject",
          "url": new URL('/logo.png', Astro.site).href,
        },
      },
    })} />
  </Fragment>

  <article class="site-section pt-28 md:pt-36 pb-16">
    <div class="site-container">
      <div class="max-w-[72ch] mx-auto">
        <!-- Back link -->
        <a
          href="/blog/"
          class="inline-flex items-center gap-1.5 text-[13px] text-[var(--site-text-tertiary)] hover:text-[var(--site-accent)] transition-colors mb-8"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/>
          </svg>
          Back to blog
        </a>

        <!-- Header -->
        <header class="mb-10">
          <h1 class="text-[clamp(1.75rem,4vw+0.5rem,2.75rem)] font-bold tracking-tight leading-[1.15] mb-4" style="font-family: var(--font-headline);">
            {title}
          </h1>
          <PostMeta date={date} updatedDate={updatedDate} author={author} />
          {tags.length > 0 && (
            <div class="mt-4">
              <TagList tags={tags} />
            </div>
          )}
        </header>

        <!-- Content -->
        <div class="prose">
          <slot />
        </div>

        <!-- Related Content -->
        {relatedContent && relatedContent.length > 0 && (
          <RelatedContent items={relatedContent} />
        )}
      </div>
    </div>
  </article>
</BaseLayout>
