---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';

const allIntegrations = await getCollection('integrations');
const integrations = allIntegrations.sort((a, b) => a.data.order - b.data.order);

const defaultIcons: Record<string, string> = {
  'claude-code': 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  'codex': 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zM8 12h8M12 8v8',
  'opencode': 'M16 18l6-6-6-6M8 6l-6 6 6 6',
};
---

<BaseLayout
  title="AI Coding Agent Integrations — Stoneforge Multi-Agent Platform"
  description="Integrate Stoneforge with leading AI coding agents. Orchestrate Claude Code, Codex, and OpenCode in parallel with automatic merge and dependency-aware dispatch."
>
  <section class="site-section pt-28 md:pt-36 pb-16">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-16">
          <SectionLabel class="mb-4">Integrations</SectionLabel>
          <h1
            class="text-[clamp(1.75rem,4vw+0.5rem,2.75rem)] font-bold tracking-tight mb-4"
            style="font-family: var(--font-headline);"
            data-reveal
          >
            Orchestrate any AI coding agent
          </h1>
          <p class="text-[var(--site-text-secondary)] text-lg max-w-2xl mx-auto" data-reveal>
            Stoneforge works with the best AI coding agents. Run multiple instances in parallel, manage context, handle merging, and recover from failures — automatically.
          </p>
        </div>

        <!-- Integration grid -->
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
          {integrations.map(integration => (
            <a
              href={`/integrations/${integration.id}/`}
              class="group glow-card p-6 md:p-8 flex flex-col"
            >
              <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 rounded-xl bg-[var(--site-accent-subtle)] border border-[var(--site-border-accent)] flex items-center justify-center flex-shrink-0">
                  {integration.data.logo ? (
                    <img src={integration.data.logo} alt={`${integration.data.agentName} logo`} class="w-7 h-7 object-contain" />
                  ) : (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--site-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d={defaultIcons[integration.id] || defaultIcons['claude-code']} />
                    </svg>
                  )}
                </div>
              </div>
              <h2 class="text-base font-semibold text-[var(--site-text-primary)] group-hover:text-[var(--site-accent)] transition-colors leading-snug mb-2" style="font-family: var(--font-headline);">
                {integration.data.agentName}
              </h2>
              <p class="text-sm text-[var(--site-text-tertiary)] leading-relaxed flex-1">
                {integration.data.description}
              </p>
              <div class="mt-4 pt-4 border-t border-[var(--site-border)]">
                <span class="text-[12px] font-medium text-[var(--site-accent)] group-hover:underline">
                  View integration &rarr;
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
