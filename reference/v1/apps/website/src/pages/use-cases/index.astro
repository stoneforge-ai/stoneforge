---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';

const allUseCases = await getCollection('use-cases');
const useCases = allUseCases.sort((a, b) => a.data.order - b.data.order);

const defaultIcons: Record<string, string> = {
  'parallel-feature-development': 'M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01',
  'large-scale-refactoring': 'M4 4h16v16H4zM9 9h6v6H9z',
  'bug-triage-and-fixing': 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM12 8v4M12 16h.01',
  'test-generation': 'M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11',
  'documentation-generation': 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8',
  'code-review-automation': 'M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2zM22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z',
  'framework-migrations': 'M17 1l4 4-4 4M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4M21 13v2a4 4 0 01-4 4H3',
};
---

<BaseLayout
  title="AI Coding Agent Use Cases — Stoneforge Multi-Agent Orchestration"
  description="Discover how teams use Stoneforge to orchestrate AI coding agents for parallel feature development, large-scale refactoring, automated testing, and code review."
>
  <section class="site-section pt-28 md:pt-36 pb-16">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-16">
          <SectionLabel class="mb-4">Use Cases</SectionLabel>
          <h1
            class="text-[clamp(1.75rem,4vw+0.5rem,2.75rem)] font-bold tracking-tight mb-4"
            style="font-family: var(--font-headline);"
            data-reveal
          >
            What teams build with AI coding agent orchestration
          </h1>
          <p class="text-[var(--site-text-secondary)] text-lg max-w-2xl mx-auto" data-reveal>
            From parallel feature development to automated code review, see how engineering teams use AI agent orchestration to ship faster.
          </p>
        </div>

        <!-- Use case grid -->
        <div class="grid gap-5 md:grid-cols-2" data-reveal-stagger>
          {useCases.map(useCase => (
            <a
              href={`/use-cases/${useCase.id}/`}
              class="group glow-card p-6 md:p-8 flex flex-col"
            >
              <div class="flex items-start gap-4 mb-4">
                <div class="w-10 h-10 rounded-xl bg-[var(--site-accent-subtle)] border border-[var(--site-border-accent)] flex items-center justify-center flex-shrink-0">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--site-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d={defaultIcons[useCase.id] || defaultIcons['parallel-feature-development']} />
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <h2 class="text-base font-semibold text-[var(--site-text-primary)] group-hover:text-[var(--site-accent)] transition-colors leading-snug mb-2" style="font-family: var(--font-headline);">
                    {useCase.data.title}
                  </h2>
                  <p class="text-sm text-[var(--site-text-tertiary)] leading-relaxed">
                    {useCase.data.description}
                  </p>
                </div>
              </div>
              <div class="mt-auto pt-4 border-t border-[var(--site-border)]">
                <span class="text-[12px] font-medium text-[var(--site-accent)] group-hover:underline">
                  Learn more &rarr;
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
