---
import PostMeta from './PostMeta.astro';
import TagList from './TagList.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  author: { name: string; url?: string; avatar?: string };
  tags: string[];
  slug: string;
  body?: string;
}

const { title, description, date, updatedDate, author, tags, slug, body } = Astro.props;
---

<div class="glow-card p-6 group relative">
  <a href={`/blog/${slug}/`} class="absolute inset-0 z-0" aria-label={title}></a>
  <h3 class="text-lg font-semibold tracking-tight mb-2 text-[var(--site-text-primary)] group-hover:text-[var(--site-accent-bright)] transition-colors duration-300" style="font-family: var(--font-headline);">
    {title}
  </h3>
  <p class="text-sm text-[var(--site-text-secondary)] leading-relaxed mb-4 line-clamp-2">
    {description}
  </p>
  <PostMeta date={date} updatedDate={updatedDate} author={author} body={body} />
  {tags.length > 0 && (
    <div class="mt-3 relative z-10">
      <TagList tags={tags} />
    </div>
  )}
</div>
