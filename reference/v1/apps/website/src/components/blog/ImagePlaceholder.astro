---
interface Props {
  prompt: string;
  alt: string;
  caption?: string;
}

const { prompt, alt, caption } = Astro.props;
---

<figure class="image-placeholder">
  <div class="image-placeholder-box">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
      <circle cx="8.5" cy="8.5" r="1.5"/>
      <polyline points="21 15 16 10 5 21"/>
    </svg>
    <p class="image-placeholder-alt">{alt}</p>
    <details>
      <summary>Generation prompt</summary>
      <p class="image-placeholder-prompt">{prompt}</p>
    </details>
  </div>
  {caption && <figcaption class="image-placeholder-caption">{caption}</figcaption>}
</figure>

<style>
  .image-placeholder {
    margin: 2rem 0;
  }

  .image-placeholder-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2.5rem 2rem;
    border-radius: 12px;
    border: 1px dashed var(--site-border-accent, rgba(255,255,255,0.12));
    background: var(--site-bg-surface, rgba(255,255,255,0.03));
    color: var(--site-text-tertiary, #666);
    text-align: center;
  }

  .image-placeholder-alt {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--site-text-secondary, #999);
    margin: 0;
  }

  details {
    width: 100%;
    max-width: 48ch;
  }

  summary {
    font-size: 0.75rem;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  summary:hover {
    opacity: 0.8;
  }

  .image-placeholder-prompt {
    font-size: 0.75rem;
    line-height: 1.6;
    margin: 0.5rem 0 0;
    opacity: 0.6;
  }

  .image-placeholder-caption {
    font-size: 0.875rem;
    color: var(--site-text-tertiary, #888);
    text-align: center;
    margin-top: 0.75rem;
    line-height: 1.5;
    font-style: italic;
  }
</style>
