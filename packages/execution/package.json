{
  "name": "@stoneforge/execution",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "smoke:providers": "STONEFORGE_PROVIDER_SMOKE=1 vitest run src/providers.smoke.test.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "effect": "^3.19.7",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
