{
  "name": "@stoneforge/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared Stoneforge V2 domain primitives",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal/program-runtime": {
      "types": "./dist/internal/program-runtime.d.ts",
      "import": "./dist/internal/program-runtime.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "pnpm run typecheck",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
