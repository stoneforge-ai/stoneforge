---
import type { StarlightRouteData } from '@astrojs/starlight/route-data';
import Default from '@astrojs/starlight/components/Head.astro';

const route = Astro.locals.starlightRoute as StarlightRouteData;
const pageTitle = route?.entry?.data?.title;
const title = pageTitle
  ? `${pageTitle} | Stoneforge Docs`
  : 'Stoneforge Docs — Multi-Agent Orchestration Platform';
const description = route?.entry?.data?.description
  || 'Documentation for Stoneforge, the open-source multi-agent orchestration platform for AI coding agents.';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL('/og.png', Astro.site);

// --- JSON-LD Structured Data ---
const siteUrl = 'https://docs.stoneforge.ai';
const pathname = Astro.url.pathname;
const slug = route?.entry?.slug || route?.slug || '';

// WebSite schema (every page)
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Stoneforge Documentation',
  url: siteUrl,
  publisher: {
    '@type': 'Organization',
    name: 'Stoneforge',
    url: 'https://stoneforge.ai',
  },
};

// BreadcrumbList schema (every page except homepage)
function buildBreadcrumbs(pagePath: string) {
  // Remove leading/trailing slashes, split into segments
  const segments = pagePath.replace(/^\/|\/$/g, '').split('/').filter(Boolean);
  if (segments.length === 0) return null;

  const items = [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
  ];

  // Build breadcrumb items from path segments
  let currentPath = '';
  for (let i = 0; i < segments.length; i++) {
    currentPath += `/${segments[i]}`;
    const name = segments[i]
      .split('-')
      .map((w: string) => w.charAt(0).toUpperCase() + w.slice(1))
      .join(' ');
    items.push({
      '@type': 'ListItem',
      position: i + 2,
      name: i === segments.length - 1 && pageTitle ? pageTitle : name,
      item: `${siteUrl}${currentPath}/`,
    });
  }

  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items,
  };
}

const breadcrumbSchema = buildBreadcrumbs(pathname);

// Determine page section from slug
const isGuide = slug.startsWith('guides/');
const isReference = slug.startsWith('reference/');
const isCoreConceptOrGettingStarted = slug.startsWith('core-concepts/') || slug.startsWith('getting-started/');
const isCommunity = slug.startsWith('community/');
const isHomepage = pathname === '/' || slug === '';

// Article/TechArticle schema for content pages
function buildArticleSchema() {
  if (isHomepage || !pageTitle) return null;

  const author = {
    '@type': 'Organization',
    name: 'Stoneforge',
    url: 'https://stoneforge.ai',
  };

  if (isReference) {
    return {
      '@context': 'https://schema.org',
      '@type': 'TechArticle',
      headline: pageTitle,
      description,
      author,
      publisher: { '@type': 'Organization', name: 'Stoneforge' },
      url: canonicalUrl.href,
      applicationCategory: 'DeveloperApplication',
      proficiencyLevel: 'Advanced',
    };
  }

  if (isGuide) {
    return {
      '@context': 'https://schema.org',
      '@type': 'TechArticle',
      headline: pageTitle,
      description,
      author,
      publisher: { '@type': 'Organization', name: 'Stoneforge' },
      url: canonicalUrl.href,
    };
  }

  // Core concepts, getting started, community pages
  if (isCoreConceptOrGettingStarted || isCommunity) {
    return {
      '@context': 'https://schema.org',
      '@type': 'TechArticle',
      headline: pageTitle,
      description,
      author,
      publisher: { '@type': 'Organization', name: 'Stoneforge' },
      url: canonicalUrl.href,
    };
  }

  return null;
}

const articleSchema = buildArticleSchema();

// Combine all schemas into a single @graph
const jsonLdSchemas: Record<string, unknown>[] = [websiteSchema];
if (breadcrumbSchema) jsonLdSchemas.push(breadcrumbSchema);
if (articleSchema) jsonLdSchemas.push(articleSchema);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': jsonLdSchemas.map(({ '@context': _ctx, ...rest }) => rest),
});
---

<Default {...Astro.props}><slot /></Default>

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={jsonLd} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Stoneforge Docs" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@stoneforge_ai" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<!-- Google Fonts: Space Grotesk (headings), IBM Plex Sans (body), JetBrains Mono (code) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
  rel="stylesheet"
/>

<!-- Plausible Analytics -->
<script is:inline defer data-domain="docs.stoneforge.ai" src="https://plausible.io/js/script.tagged-events.outbound-links.js"></script>
<script is:inline>
window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) };
</script>

<!-- Plausible Custom Events -->
<script is:inline>
(function() {
  // Use the queue-backed plausible function — always available thanks to the queue pattern above.
  var plausible = window.plausible;

  // --- Global listeners (registered once, use event delegation) ---

  // 1. marketing-site-click — clicks to stoneforge.ai (marketing site)
  // 2. github-click — clicks to GitHub links
  // 5. copy-code — user clicks a code block copy button
  document.addEventListener('click', function(e) {
    var link = e.target.closest('a[href]');
    if (link) {
      var href = link.getAttribute('href') || '';
      // Match stoneforge.ai links but not docs.stoneforge.ai
      if (/^https?:\/\/(www\.)?stoneforge\.ai(\/|$)/.test(href)) {
        plausible('marketing-site-click', { props: { url: href } });
      }
      if (/^https?:\/\/(www\.)?github\.com\//.test(href)) {
        plausible('github-click', { props: { url: href } });
      }
    }

    // Copy code button (expressive-code renders .copy > button[data-code])
    var btn = e.target.closest('.copy button, .expressive-code button[data-code]');
    if (btn) {
      plausible('copy-code', { props: { path: window.location.pathname } });
    }
  });

  // 4. search-use — keyboard shortcut (Ctrl/Cmd+K)
  document.addEventListener('keydown', function(e) {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      plausible('search-use');
    }
  });

  // --- Per-page listeners (re-bind on View Transition navigations) ---
  function setupPageAnalytics() {
    // 3. guide-complete — scroll past 75% of guide pages
    if (/\/guides\//.test(window.location.pathname)) {
      var guideTracked = false;
      var sentinel = document.createElement('div');
      sentinel.style.cssText = 'position:absolute;width:1px;height:1px;opacity:0;pointer-events:none';
      var mainContent = document.querySelector('.sl-markdown-content') || document.querySelector('main');
      if (mainContent) {
        mainContent.style.position = mainContent.style.position || 'relative';
        mainContent.appendChild(sentinel);
        sentinel.style.top = Math.floor(mainContent.scrollHeight * 0.75) + 'px';
        var guideObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting && !guideTracked) {
              guideTracked = true;
              plausible('guide-complete', { props: { path: window.location.pathname } });
              guideObserver.disconnect();
            }
          });
        }, { threshold: 0 });
        guideObserver.observe(sentinel);
      }
    }

    // 4. search-use — click on search button (re-bind per page since button may be replaced)
    var searchBtn = document.querySelector('button[data-open-modal]');
    if (searchBtn) {
      searchBtn.addEventListener('click', function() {
        plausible('search-use');
      });
    }

    // 6. sidebar-navigate — click on sidebar link (event delegation on sidebar container)
    var sidebar = document.querySelector('nav.sidebar');
    if (sidebar && !sidebar._sfAnalytics) {
      sidebar._sfAnalytics = true;
      sidebar.addEventListener('click', function(e) {
        var link = e.target.closest('a[href]');
        if (link) {
          plausible('sidebar-navigate', { props: { target: link.getAttribute('href') } });
        }
      });
    }
  }

  // Run on initial page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupPageAnalytics);
  } else {
    setupPageAnalytics();
  }
})();
</script>

<!-- Scroll reveal IntersectionObserver -->
<script is:inline>
(function() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    // Make all reveal elements immediately visible
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[data-sf-reveal], [data-sf-stagger]').forEach(function(el) {
        el.classList.add('sf-revealed');
      });
    });
    return;
  }

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('sf-revealed');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.1,
    rootMargin: '0px 0px -40px 0px'
  });

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-sf-reveal], [data-sf-stagger]').forEach(function(el) {
      observer.observe(el);
    });
  });
})();
</script>
