# Stoneforge Feed - Environment Variables

# Required for remote access — set to a random secret (used for sync API auth)
AUTH_TOKEN=your-secret-token-here

# Human-friendly login password for browser access (defaults to AUTH_TOKEN if unset)
# FEED_PASSWORD=your-password-here

# Set to "true" on Railway — feed waits for Mac to push data via /api/sync/push
# Set to "false" or omit for demo mode with fake agents
SYNC_MODE=false

# Server port (Railway sets this automatically)
PORT=8080

# Session secret for cookie auth (defaults to AUTH_TOKEN if unset)
# SESSION_SECRET=your-session-secret

# Set to "1" behind a reverse proxy (Railway, nginx, etc.)
# TRUST_PROXY=1

# PostgreSQL connection string (omit for SQLite default)
# DATABASE_URL=postgresql://stoneforge:stoneforge@localhost:5432/feed

# --- Docker Compose postgres profile ---
# PG_USER=stoneforge
# PG_PASSWORD=stoneforge
# PG_DB=feed
# PG_PORT=5432

# Feed port mapping for docker-compose
# FEED_PORT=8080
